{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a hostel resident or admin.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "room": { "type": "string" },
        "rentPaid": { "type": "boolean" },
        "billPaid": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["name", "email", "role"]
    },
    "MealMenu": {
      "title": "Meal Menu",
      "description": "Daily food menu for the hostel.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "breakfast": { "type": "string" },
        "lunch": { "type": "string" },
        "dinner": { "type": "string" }
      },
      "required": ["date"]
    },
    "MealRecord": {
      "title": "Meal Record",
      "description": "A record of a meal status for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["ON", "OFF"] },
        "type": { "type": "string", "enum": ["breakfast", "lunch", "dinner"] }
      },
      "required": ["userId", "date", "status", "type"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Bazar cost or other hostel expenses.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "title": { "type": "string" },
        "amount": { "type": "number" }
      },
      "required": ["date", "title", "amount"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment record for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["rent", "meal", "wifi"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["userId", "type", "amount", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and status."
    },
    "/menu/{date}": {
      "schema": "MealMenu",
      "description": "Daily food menu."
    },
    "/meals/{mealId}": {
      "schema": "MealRecord",
      "description": "Individual meal records."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Hostel expenses."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "User payment records."
    }
  }
}
